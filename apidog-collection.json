{
  "openapi": "3.0.0",
  "info": {
    "title": "KlikBelanja API (Toko API)",
    "version": "1.0.0",
    "description": "API Documentation for KlikBelanja / Toko API. File ini dapat di-import langsung ke dalam Apidog."
  },
  "servers": [
    {
      "url": "https://learn.smktelkom-mlg.sch.id/toko/api",
      "description": "Production Backend"
    },
    {
      "url": "http://localhost:3000/api/proxy",
      "description": "Local Next.js Proxy"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login User",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful login"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register User",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "telepon": { "type": "string", "example": "081234567890" },
                  "password": { "type": "string", "example": "password123" },
                  "alamat": { "type": "string", "example": "Jl. Mawar No. 12" },
                  "role": { "type": "string", "enum": ["user", "admin"], "example": "user" },
                  "foto_profil": { "type": "string", "format": "binary" }
                },
                "required": ["name", "email", "password", "role"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful registration" }
        }
      }
    },
    "/admin/getbarang": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get all products (Admin)",
        "responses": {
          "200": { "description": "List of products" }
        }
      }
    },
    "/admin/insertbarang": {
      "post": {
        "tags": ["Admin"],
        "summary": "Insert new product",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama_barang": { "type": "string", "example": "Laptop ASUS" },
                  "deskripsi": { "type": "string", "example": "Laptop gaming kencang" },
                  "harga": { "type": "integer", "example": 15000000 },
                  "stok": { "type": "integer", "example": 10 },
                  "image": { "type": "string", "format": "binary" }
                },
                "required": ["nama_barang", "deskripsi", "harga", "stok"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Product inserted" }
        }
      }
    },
    "/admin/updatebarang/{id}": {
      "post": {
        "tags": ["Admin"],
        "summary": "Update product",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "nama_barang": { "type": "string" },
                  "deskripsi": { "type": "string" },
                  "harga": { "type": "integer" },
                  "stok": { "type": "integer" },
                  "image": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Product updated" }
        }
      }
    },
    "/admin/hapusbarang/{id}": {
      "delete": {
        "tags": ["Admin"],
        "summary": "Delete product",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "example": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Product deleted" }
        }
      }
    },
    "/user/getbarang": {
      "get": {
        "tags": ["User"],
        "summary": "Get all products (User)",
        "responses": {
          "200": { "description": "List of products" }
        }
      }
    },
    "/user/history_trans": {
      "get": {
        "tags": ["User"],
        "summary": "Get transaction history",
        "responses": {
          "200": { "description": "Transaction history" }
        }
      }
    },
    "/user/transaksi": {
      "post": {
        "tags": ["User"],
        "summary": "Submit a transaction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pesan": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "barang_id": { "type": "integer", "example": 1 },
                        "qty": { "type": "integer", "example": 2 }
                      },
                      "required": ["barang_id", "qty"]
                    }
                  }
                },
                "required": ["pesan"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Transaction created" }
        }
      }
    }
  }
}
